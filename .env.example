# 이 파일을 복사해서 .env.local 을 만들고 값을 채우세요.
# Vercel 배포 시에도 아래 4개 변수를 프로젝트 환경변수에 등록하세요.

# Supabase (프로젝트 설정 > API 에서 확인)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key

# 토스페이먼츠 (https://developers.tosspayments.com)
# 결제창 방식이라 "API 개별 연동 키"(ck/sk)를 사용하세요. 위젯 키(gck/gsk) 아님!
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_ck_xxxxxxxxxxxxxxxx
TOSS_SECRET_KEY=test_sk_xxxxxxxxxxxxxxxx
